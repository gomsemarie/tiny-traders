{
  "folders": [
    { "path": ".", "name": "root" },
    { "path": "client", "name": "client" },
    { "path": "server", "name": "server" }
  ],
  "settings": {
    "typescript.tsdk": "node_modules/typescript/lib",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "files.eol": "\n",
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/pnpm-lock.yaml": true
    },
    "github.copilot.chat.commitMessageGeneration.instructions": [
      { "text": "Conventional Commits 형식으로 한글 커밋 메시지를 작성하세요.\n\n형식: <type>(<scope>): <한글 설명>\n\ntype: feat, fix, refactor, style, docs, test, chore, perf, ci, build\nscope: client, server, db, config 등 (선택)\n설명: 한글로 50자 이내\n\n예시:\nfeat(client): 로그인 페이지 추가\nfix(server): 주문 체결 로직 수정\nrefactor: 다크테마를 라이트테마로 전환\nstyle(client): 대시보드 레이아웃 정리\nchore: 불필요한 파일 정리" }
    ],
    "claude-dev.commitMessageLanguage": "ko"
  },
  "extensions": {
    "recommendations": [
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "bradlc.vscode-tailwindcss"
    ]
  }
}
